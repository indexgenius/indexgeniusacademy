rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNCIONES DE SEGURIDAD ---
    function isAuthenticated() { return request.auth != null; }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email in ['admin', 'steven@ingenius.fx', 'pipoapaza@gmail.com', 'jeilin@jeilin.com', 'jeilin@jeilin.fx']
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email in ['admin', 'steven@ingenius.fx', 'pipoapaza@gmail.com', 'jeilin@jeilin.com', 'jeilin@jeilin.fx']
             || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
             || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canBroadcast == true
           ))
      );
    }
    
    function isApproved() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    // --- REGLAS TÁCTICAS ---

    match /users/{userId} {
      allow read, write: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
    }

    match /signals/{id} {
      allow read: if isAdmin() || isApproved();
      allow write: if isAdmin();
    }

    match /academy_videos/{id} {
      allow read: if isAdmin() || isApproved();
      allow write: if isAdmin();
    }

    match /lives/{id} {
      allow read: if isAdmin() || isApproved();
      allow write: if isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      match /messages/{msgId} {
        // Solo aprobados pueden chatear
        allow read, write: if isAdmin() || isApproved();
      }
    }

    match /access_codes/{codeId} {
      // BLINDAJE: Solo permite validar 1 código (get). Prohíbe ver la lista (list).
      allow get: if isAuthenticated();
      allow list, write: if isAdmin();
    }

    match /notifications/{id} {
      allow create: if isAuthenticated(); // Reportar pago
      allow read, update, delete: if isAdmin(); // Solo tú gestionas los avisos
    }

    match /announcements/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /payment_methods/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /promos/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }

    match /site_assets/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- NUEVO: CÓDIGOS DE DESCUENTO ---
    match /discount_codes/{codeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
