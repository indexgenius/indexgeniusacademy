rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- SEGURIDAD DE ACCESO ---
    function isAuthenticated() { return request.auth != null; }
    
    // Lista de correos maestros (Administradores Supremos)
    function isMasterAdmin() {
      return isAuthenticated() && 
        request.auth.token.email != null && (
        request.auth.token.email.lower() == 'admin' ||
        request.auth.token.email.lower() == 'steven@ingenius.fx' ||
        request.auth.token.email.lower() == 'pipoapaza@gmail.com' ||
        request.auth.token.email.lower() == 'jeilin@jeilin.com' ||
        request.auth.token.email.lower() == 'jeilin@jeilin.fx' ||
        request.auth.token.email.lower() == 'jeilin@ingenus.fx'
      );
    }

    function isAdmin() {
      return isMasterAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canBroadcast == true
        )
      );
    }
    
    function isApproved() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    // --- REGLAS POR COLECCIÓN ---

    match /users/{userId} {
      allow read, write: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
    }

    match /signals/{id} {
      allow read: if isAdmin() || isApproved();
      allow write: if isAdmin();
    }

    match /academy_videos/{id} {
      allow read: if isAdmin() || isApproved();
      allow write: if isAdmin();
    }

    match /lives/{id} {
      allow read: if isAdmin() || isApproved();
      allow write: if isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      match /messages/{msgId} {
        allow read, write: if isAdmin() || isApproved();
      }
    }

    match /access_codes/{codeId} {
      allow get: if isAuthenticated();
      allow list, write: if isAdmin();
    }

    match /notifications/{id} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /announcements/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /payment_methods/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /promos/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /site_assets/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /discount_codes/{codeId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /payment_logs/{id} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.userId);
      allow update, delete: if isAdmin();
    }

    // Permitir a los admins leer cualquier colección por si acaso
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
