rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- SEGURIDAD DE ACCESO ---
    function isAuthenticated() { return request.auth != null; }
    
    // Lista de correos maestros (Administradores Supremos)
    function isMasterAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.matches("(?i)(admin|steven@ingenius.fx|pipoapaza@gmail.com|jeilin@jeilin.com|jeilin@jeilin.fx|jeilin@ingenus.fx).*"));
    }

    function isAdmin() {
      return isMasterAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canBroadcast == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email.matches("(?i)(admin|steven@ingenius.fx|pipoapaza@gmail.com|jeilin@jeilin.com|jeilin@jeilin.fx|jeilin@ingenus.fx).*")
        )
      );
    }
    
    function isApproved() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    // --- REGLAS POR COLECCIÓN ---

    match /users/{userId} {
      // Un usuario solo puede leer/escribir su propio documento, a menos que sea Admin
      allow read, write: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
    }

    match /signals/{id} {
      allow read: if isAdmin() || isApproved();
      allow write: if isAdmin();
    }

    match /academy_videos/{id} {
      allow read: if isAdmin() || isApproved();
      allow write: if isAdmin();
    }

    match /lives/{id} {
      allow read: if isAdmin() || isApproved();
      allow write: if isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      match /messages/{msgId} {
        allow read, write: if isAdmin() || isApproved();
      }
    }

    match /access_codes/{codeId} {
      allow get: if isAuthenticated();
      allow list, write: if isAdmin();
    }

    match /notifications/{id} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /announcements/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /payment_methods/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /promos/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /site_assets/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /discount_codes/{codeId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /announcements/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }

    // Permitir a los admins leer cualquier colección por si acaso
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
